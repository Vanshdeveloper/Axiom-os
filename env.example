# Axiom OS — Environment Configuration Template
# Copy this file to .env and fill in your credentials.

# ---------------------------------------------------------
# 1. CORE API KEYS
# ---------------------------------------------------------

# Google Gemini API Key (Get it from: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (Get it from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Notion Integration Token (Create an integration at: https://www.notion.so/my-integrations)
NOTION_API_KEY=your_notion_api_key_here
TIMEZONE=Asia/Kolkata

# ---------------------------------------------------------
# 2. NOTION DATABASE IDs
# ---------------------------------------------------------
# To find a Database ID: 
# Open the database in Notion, the ID is the 32-character string in the URL 
# after your workspace name and before the '?' (e.g., notion.so/workspace/ID?v=...)

# Note Vault (Where academic/study notes are saved)
DATABASE_ID=your_vault_database_id

# Task Backlog (For /add, /show, /done commands)
BACKLOG_DB_ID=your_backlog_database_id

# Finance Tracker (For expense tracking and budgeting)
FINANCE_DB_ID=your_finance_database_id

# Habit Tracker (Optional: For /habits command)
HABITS_DB_ID=your_habits_database_id

# ---------------------------------------------------------
# 3. SERVER CONFIGURATION
# ---------------------------------------------------------
PORT=3000
NODE_ENV=development

# Optional: Path to a custom Chromium/Chrome executable.
# Useful if the automated browser installation fails in specific environments.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
